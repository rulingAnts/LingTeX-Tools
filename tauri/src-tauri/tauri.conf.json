{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LingTeX Tools",
  "version": "0.3.0",
  "identifier": "com.rulingants.lingtex-tools",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LingTeX Tools",
        "width": 500,
        "height": 720,
        "minWidth": 420,
        "minHeight": 400,
        "resizable": true,
        "visible": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
