# ── Tauri / Rust ──────────────────────────────────────────────────────────────
# Rust build cache — can be several GB; fully reproducible via `cargo build`
tauri/src-tauri/target/

# Tauri-generated capability schemas — recreated on every `cargo tauri build/dev`
tauri/src-tauri/gen/

# core.js is synced from docs/core.js by build scripts — not a source file here
tauri/src/core.js

# Windows installer toolchain downloaded by Tauri on first Windows build
tauri/src-tauri/WixTools/

# ── Browser extension — generated files ───────────────────────────────────────
# These are assembled from extension/shared/ by extension/build.sh.
# Only extension/{chrome,firefox}/manifest.json are tracked source files.

extension/chrome/core.js
extension/chrome/content.js
extension/chrome/background.js
extension/chrome/popup.html
extension/chrome/popup.js
extension/chrome/icons/

extension/firefox/core.js
extension/firefox/content.js
extension/firefox/background.js
extension/firefox/popup.html
extension/firefox/popup.js
extension/firefox/icons/

# Safari extension — entirely generated by xcrun + xcodebuild in CI
extension/safari/LingTeX\ Tools/
extension/safari/build/

# Distribution zips (produced by extension/build.sh --zip and the release workflow)
extension/*.zip

# ── Build / release artifacts ─────────────────────────────────────────────────
*.dmg
*.pkg
*.msi
*.exe
*.AppImage
*.deb
*.rpm

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.tmp
