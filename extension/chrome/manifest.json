{
  "manifest_version": 3,
  "name": "LingTeX Tools",
  "version": "0.1.0",
  "description": "Convert FLEx, Phonology Assistant, and TSV data to LaTeX as you paste. Press Ctrl+Shift+V / ⌘⇧V to smart-paste anywhere.",

  "permissions": [
    "storage",
    "clipboardRead",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "LingTeX Tools"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["core.js", "content.js"],
      "run_at": "document_idle"
    }
  ],

  "commands": {
    "smart-paste": {
      "suggested_key": {
        "default": "Ctrl+Shift+V",
        "mac": "Command+Shift+V"
      },
      "description": "Paste clipboard as LaTeX (LingTeX conversion)"
    }
  }
}
