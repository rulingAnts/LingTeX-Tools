{
  "manifest_version": 2,
  "name": "LingTeX Tools",
  "version": "0.3.0",
  "description": "Convert FLEx, Phonology Assistant, and TSV data to LaTeX as you paste. Press Ctrl+Shift+V / ⌘⇧V to smart-paste anywhere.",

  "permissions": [
    "storage",
    "clipboardRead",
    "clipboardWrite",
    "activeTab",
    "<all_urls>"
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "LingTeX Tools",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["core.js", "content.js"],
      "run_at": "document_idle"
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "lingtex-tools@rulingAnts",
      "strict_min_version": "109.0"
    }
  }
}
